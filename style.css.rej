 .slide {
     position: absolute;
     width: 100%;
     height: 100%;
     object-fit: contain;
     opacity: 0;
     transition: opacity 1s ease-in-out;
 }
 
+.hero-visual .slider-container {
+    position: relative;
+}
+
 .slide.active {
     opacity: 1;
 }
 
+.cards-3 {
+    display: grid;
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+    gap: 0.8rem;
+    margin-bottom: 1rem;
+}
+
+.card {
+    background: rgba(255, 255, 255, 0.06);
+    border: 1px solid rgba(255, 255, 255, 0.1);
+    border-radius: 14px;
