+}
+
+.split {
+    display: grid;
+    grid-template-columns: 1fr 1fr;
+    gap: 1rem;
+}
+
+.contact-panel {
+    background: linear-gradient(130deg, rgba(34, 211, 238, 0.16), rgba(167, 139, 250, 0.16));
+}
+
+.contact-grid {
+    display: grid;
+    gap: 0.4rem;
+}
 
+footer {
+    text-align: center;
+    padding: 0.4rem 1rem 1.4rem;
+    color: #9eb0da;
+}
+
+@media (max-width: 900px) {
